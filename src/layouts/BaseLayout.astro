---
import { site } from '@/lib/site';
const { title = site.title, description = site.description } = Astro.props;
const fullTitle = title === site.title ? title : `${title} - ${site.title}`;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.png" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-mark">小</span>
          <span>
            <strong>{site.title}</strong>
            <em>{site.subtitle}</em>
          </span>
        </a>
        <nav class="nav">
          {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>© {new Date().getFullYear()} {site.author}. Built with Astro. 音乐模块预留，暂缓上线。</p>
      </footer>
    </div>
  </body>
</html>
