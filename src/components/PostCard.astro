---
import { formatDate, getExcerpt, getPostUrl } from '@/lib/posts';
const { post, featured = false } = Astro.props;
const url = getPostUrl(post);
const cover = post.data.cover || `/medias/featureimages/${(post.id.length % 24) + 1}.jpg`;
const excerpt = post.data.description || getExcerpt(post.body || '', featured ? 190 : 120);
---
<div class:list={["article", "col", { featured }]} data-aos="zoom-in">
  <div class="card">
    <a href={url}>
      <div class="card-image" style={`background-image:url('${cover}')`}>
        <span class="card-title">{post.data.title}</span>
      </div>
    </a>
    <div class="card-content article-content">
      <div class="summary block-with-text">{excerpt}</div>
      <div class="publish-info">
        <span class="publish-date"><i class="far fa-clock fa-fw icon-date"></i>{formatDate(post.data.date)}</span>
        <span class="publish-author"><i class="fas fa-bookmark fa-fw icon-category"></i>{post.data.categories?.join(' / ')}</span>
      </div>
    </div>
    <div class="card-action article-tags">
      {post.data.tags?.slice(0, 5).map((tag) => <a href={`/tags/${encodeURIComponent(tag)}/`}><span class="chip bg-color">{tag}</span></a>)}
    </div>
  </div>
</div>
