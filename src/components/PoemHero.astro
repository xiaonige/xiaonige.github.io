---
import { site } from '@/lib/site';
const { postsCount = 0 } = Astro.props;
---
<section class="matery-cover bg-cover">
  <div class="cover-overlay"></div>
  <div class="cover-content container">
    <div class="brand center-align">
      <h1>{site.blogTitle}</h1>
      <div class="description center-align">
        <span>{site.poem.text}</span>
      </div>
      <p class="poem-from">{site.poem.from}</p>
    </div>
    <div class="cover-btns">
      <a class="waves-effect btn" href="#indexCard"><i class="fa fa-angle-double-down"></i> 开始阅读</a>
      <a class="waves-effect btn github" href={site.social.github} target="_blank"><i class="fab fa-github-alt"></i> Github</a>
    </div>
    <div class="cover-social-link">
      <a title="GitHub" href={site.social.github} target="_blank"><i class="fab fa-github"></i></a>
      <a title="Email" href={site.social.email} target="_blank"><i class="fas fa-envelope-open"></i></a>
      <a title="QQ" href={site.social.qq} target="_blank"><i class="fab fa-qq"></i></a>
    </div>
    <div class="cover-stats">已迁移文章 {postsCount} 篇 · Astro 预览版 · 音乐暂缓</div>
  </div>
</section>
