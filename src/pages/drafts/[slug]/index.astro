---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleToc from '@/components/ArticleToc.astro';
import PostExtras from '@/components/PostExtras.astro';
import { getDrafts, formatDate, getWordCount, getReadingMinutes } from '@/lib/posts';
import plantumlManifest from '../../../../public/generated/plantuml/manifest.json';
export async function getStaticPaths() {
  if (process.env.INCLUDE_DRAFTS !== 'true') return [];
  const drafts = await getDrafts();
  return drafts.map((draft) => ({
    params: { slug: draft.id.replace(/\.mdx?$/, '') },
    props: { draft }
  }));
}
const { draft } = Astro.props;
const slug = draft.id.replace(/\.mdx?$/, '');
const { Content, headings } = await draft.render();
const cover = draft.data.cover || `/medias/featureimages/${draft.id.length % 24}.jpg`;
const wordCount = getWordCount(draft.body || '');
const readingMinutes = getReadingMinutes(draft.body || '');
const plantumlImages = plantumlManifest[slug] || [];
---
<BaseLayout title={`草稿预览：${draft.data.title}`} description="草稿预览页面，不代表正式发布。" image={cover} noindex={true}>
  <section class="page-hero article-hero draft-hero" style={`background-image:url('${cover}')`}>
    <div class="cover-overlay"></div>
    <div class="page-hero-content container">
      <div class="draft-badge"><i class="fas fa-flask"></i> 草稿预览 · 不会进入正式文章列表</div>
      <h1>{draft.data.title}</h1>
      <div class="meta-line hero-meta">
        <span><i class="far fa-clock"></i> {formatDate(draft.data.date)}</span>
        <span><i class="fas fa-bookmark"></i> {draft.data.categories?.join(' / ')}</span>
        <span><i class="fas fa-tags"></i> {draft.data.tags?.join('，')}</span>
        <span><i class="fas fa-font"></i> {wordCount.toLocaleString('zh-CN')} 字</span>
        <span><i class="far fa-hourglass-half"></i> 约 {readingMinutes} 分钟</span>
        {plantumlImages.length > 0 && <span><i class="fas fa-diagram-project"></i> {plantumlImages.length} 张 PlantUML 图已预渲染</span>}
      </div>
    </div>
  </section>
  <div class="article-layout container">
    <article class="content-card prose article-content-page draft-content" data-plantuml-images={JSON.stringify(plantumlImages)}>
      <div class="draft-notice">
        <strong>草稿说明：</strong>此页面仅用于 Astro 迁移预览，不在首页、归档、标签、分类、RSS、search.xml 中出现。PlantUML 已在构建期预渲染为 SVG，源码默认折叠保留。
      </div>
      <Content />
    </article>
    <ArticleToc headings={headings} />
  </div>
  <div class="container"><PostExtras post={draft} url={`/drafts/${slug}/`} /></div>
  <script is:inline>
    const article = document.querySelector('.draft-content');
    const plantumlImages = JSON.parse(article?.dataset.plantumlImages || '[]');
    let plantumlIndex = 0;
    document.querySelectorAll('pre').forEach((pre) => {
      if (pre.querySelector('.copy-code')) return;
      const code = pre.querySelector('code');
      const lang = Array.from(code?.classList || []).find((c) => c.startsWith('language-'))?.replace('language-', '') || 'code';
      const text = code?.innerText || '';
      const isPlantUml = lang === 'plantuml' || text.trim().startsWith('@startuml');
      pre.setAttribute('data-lang', isPlantUml ? 'plantuml' : lang);
      const btn = document.createElement('button');
      btn.className = 'copy-code';
      btn.type = 'button';
      btn.textContent = '复制';
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(text || pre.innerText.replace(/^复制\n?/, ''));
          btn.textContent = '已复制';
          setTimeout(() => btn.textContent = '复制', 1200);
        } catch { btn.textContent = '失败'; }
      });
      pre.appendChild(btn);

      if (isPlantUml) {
        const image = plantumlImages[plantumlIndex++];
        const details = document.createElement('details');
        details.className = 'plantuml-source-details';
        const summary = document.createElement('summary');
        summary.textContent = '查看 PlantUML 源码';
        details.append(summary);
        pre.parentNode.insertBefore(details, pre);
        details.append(pre);
        if (image?.src) {
          const box = document.createElement('figure');
          box.className = 'plantuml-rendered';
          box.innerHTML = `<a href="${image.src}" target="_blank" rel="noopener"><img src="${image.src}" alt="PlantUML diagram ${image.index}" loading="lazy" /></a><figcaption>PlantUML 图 ${image.index} · 点击图片可新窗口查看 SVG</figcaption>`;
          details.insertAdjacentElement('beforebegin', box);
        }
      }
    });
  </script>
</BaseLayout>
