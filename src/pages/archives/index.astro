---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/PostList.astro';
import { getPosts } from '@/lib/posts';
const posts = await getPosts();
const byYear = posts.reduce((acc, post) => {
  const year = String(post.data.date.getUTCFullYear());
  (acc[year] ||= []).push(post);
  return acc;
}, {});
---
<BaseLayout title="归档">
  <section class="page-hero small-hero archive-hero">
    <div class="cover-overlay"></div>
    <div class="page-hero-content">
      <h1>文章归档</h1>
      <p>把时间线摊开，看看一路写下了什么。</p>
    </div>
  </section>
  <section class="content-card list-card">
    <p class="eyebrow"><i class="fas fa-archive"></i> ARCHIVES</p>
    {Object.entries(byYear).map(([year, items]) => (
      <section class="year-section">
        <h2>{year}</h2>
        <PostList posts={items} />
      </section>
    ))}
  </section>
</BaseLayout>
