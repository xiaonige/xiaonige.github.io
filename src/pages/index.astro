---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PoemHero from '@/components/PoemHero.astro';
import PostCard from '@/components/PostCard.astro';
import { getPosts } from '@/lib/posts';
const posts = await getPosts();
const featured = posts.slice(0, 2);
---
<BaseLayout>
  <PoemHero />
  <div class="index-card" id="indexCard">
    <div class="container">
      <div class="dream-card card-panel">
        <div class="title center-align"><i class="far fa-lightbulb"></i> 关于成长</div>
        <p>成长，是一个充满荆棘与鲜花的旅程。每一次跌倒，都是向前的动力；每一次复盘，都是下一次出发的坐标。</p>
      </div>
      <section class="recommend card-panel">
        <div class="section-title"><i class="far fa-thumbs-up"></i> 推荐文章</div>
        <div class="recommend-grid">
          {featured.map((post) => <PostCard post={post} featured />)}
        </div>
      </section>
    </div>
  </div>
  <article class="container articles" id="articles">
    <div class="section-title all-posts"><i class="fas fa-newspaper"></i> 最新文章</div>
    <div class="row article-row">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </article>
</BaseLayout>
