---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleToc from '@/components/ArticleToc.astro';
import PostNav from '@/components/PostNav.astro';
import PostExtras from '@/components/PostExtras.astro';
import { getPosts, getSlug, formatDate, getDateParts, getWordCount, getReadingMinutes, getAdjacentPosts, getRelatedPosts } from '@/lib/posts';
import { slug as githubSlug } from 'github-slugger';
import plantumlManifest from '../../../../../../public/generated/plantuml/manifest.json';
export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => {
    const { year, month, day } = getDateParts(post.data.date);
    return {
      params: {
        year,
        month,
        day,
        slug: getSlug(post)
      },
      props: { post, posts }
    };
  });
}
const { post, posts } = Astro.props;
const { Content, headings } = await post.render();
const slug = getSlug(post);
const plantumlImages = plantumlManifest[slug] || [];
const cover = post.data.cover || `/medias/featureimages/${post.id.length % 24}.jpg`;
const wordCount = getWordCount(post.body || '');
const readingMinutes = getReadingMinutes(post.body || '');
const { newer, older } = getAdjacentPosts(posts, post);
const related = getRelatedPosts(posts, post);
const tocHeadings = mergeHeadings(headings, post.body || '');

function stripHtml(value) {
  return value
    .replace(/<[^>]+>/g, '')
    .replace(/&nbsp;/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .trim();
}

function mergeHeadings(markdownHeadings, body) {
  const map = new Map((markdownHeadings || [])
    .filter((h) => h.depth >= 2 && h.depth <= 3)
    .map((h) => [h.slug, h]));
  const rawHtmlHeadings = Array.from(body.matchAll(/<h([23])\b[^>]*id=["']([^"']+)["'][^>]*>([\s\S]*?)<\/h\1>/gi))
    .map((match) => {
      const text = stripHtml(match[3]);
      const id = match[2] || githubSlug(text);
      return { depth: Number(match[1]), slug: id, text };
    })
    .filter((h) => h.text && h.slug && h.text !== '目录');
  for (const h of rawHtmlHeadings) {
    if (!map.has(h.slug)) map.set(h.slug, h);
  }
  return Array.from(map.values());
}
---
<BaseLayout title={post.data.title} description={post.data.description} image={cover}>
  <section class="page-hero article-hero" style={`background-image:url('${cover}')`}>
    <div class="cover-overlay"></div>
    <div class="page-hero-content container">
      <h1>{post.data.title}</h1>
      <div class="meta-line hero-meta">
        <span><i class="far fa-clock"></i> {formatDate(post.data.date)}</span>
        <span><i class="fas fa-bookmark"></i> {post.data.categories?.join(' / ')}</span>
        <span><i class="fas fa-tags"></i> {post.data.tags?.join('，')}</span>
        <span><i class="fas fa-font"></i> {wordCount.toLocaleString('zh-CN')} 字</span>
        <span><i class="far fa-hourglass-half"></i> 约 {readingMinutes} 分钟</span>
      </div>
    </div>
  </section>
  <div class="article-layout container">
    <article class="content-card prose article-content-page" data-plantuml-images={JSON.stringify(plantumlImages)}>
      <Content />
    </article>
    <ArticleToc headings={tocHeadings} />
  </div>
  <div class="container"><PostExtras post={post} /><PostNav newer={newer} older={older} related={related} /></div>
  <script is:inline>
    const article = document.querySelector('.article-content-page');
    const plantumlImages = JSON.parse(article?.dataset.plantumlImages || '[]');
    let plantumlIndex = 0;
    document.querySelectorAll('pre').forEach((pre) => {
      if (pre.querySelector('.copy-code')) return;
      const code = pre.querySelector('code');
      const lang = Array.from(code?.classList || []).find((c) => c.startsWith('language-'))?.replace('language-', '') || 'code';
      const text = code?.innerText || '';
      const isPlantUml = lang === 'plantuml' || text.trim().startsWith('@startuml');
      pre.setAttribute('data-lang', isPlantUml ? 'plantuml' : lang);
      const btn = document.createElement('button');
      btn.className = 'copy-code';
      btn.type = 'button';
      btn.textContent = '复制';
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(text || pre.innerText.replace(/^复制\n?/, ''));
          btn.textContent = '已复制';
          setTimeout(() => btn.textContent = '复制', 1200);
        } catch {
          btn.textContent = '失败';
        }
      });
      pre.appendChild(btn);

      if (isPlantUml) {
        const image = plantumlImages[plantumlIndex++];
        const details = document.createElement('details');
        details.className = 'plantuml-source-details';
        const summary = document.createElement('summary');
        summary.textContent = '查看 PlantUML 源码';
        details.append(summary);
        pre.parentNode.insertBefore(details, pre);
        details.append(pre);
        if (image?.src) {
          const box = document.createElement('figure');
          box.className = 'plantuml-rendered';
          box.innerHTML = `<a href="${image.src}" target="_blank" rel="noopener"><img src="${image.src}" alt="PlantUML diagram ${image.index}" loading="lazy" /></a><figcaption>PlantUML 图 ${image.index} · 点击图片可新窗口查看 SVG</figcaption>`;
          details.insertAdjacentElement('beforebegin', box);
        }
      }
      if (lang === 'mermaid') {
        pre.classList.add('mermaid-source');
      }
    });
  </script>
</BaseLayout>
