---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleToc from '@/components/ArticleToc.astro';
import PostNav from '@/components/PostNav.astro';
import PostExtras from '@/components/PostExtras.astro';
import { getPosts, formatDate, getDateParts, getWordCount, getReadingMinutes, getAdjacentPosts, getRelatedPosts } from '@/lib/posts';
export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => {
    const { year, month, day } = getDateParts(post.data.date);
    return {
      params: {
        year,
        month,
        day,
        slug: post.id.replace(/\.mdx?$/, '')
      },
      props: { post, posts }
    };
  });
}
const { post, posts } = Astro.props;
const { Content, headings } = await post.render();
const cover = post.data.cover || `/medias/featureimages/${(post.id.length % 24) + 1}.jpg`;
const wordCount = getWordCount(post.body || '');
const readingMinutes = getReadingMinutes(post.body || '');
const { newer, older } = getAdjacentPosts(posts, post);
const related = getRelatedPosts(posts, post);
---
<BaseLayout title={post.data.title} description={post.data.description} image={cover}>
  <section class="page-hero article-hero" style={`background-image:url('${cover}')`}>
    <div class="cover-overlay"></div>
    <div class="page-hero-content container">
      <h1>{post.data.title}</h1>
      <div class="meta-line hero-meta">
        <span><i class="far fa-clock"></i> {formatDate(post.data.date)}</span>
        <span><i class="fas fa-bookmark"></i> {post.data.categories?.join(' / ')}</span>
        <span><i class="fas fa-tags"></i> {post.data.tags?.join('，')}</span>
        <span><i class="fas fa-font"></i> {wordCount.toLocaleString('zh-CN')} 字</span>
        <span><i class="far fa-hourglass-half"></i> 约 {readingMinutes} 分钟</span>
      </div>
    </div>
  </section>
  <div class="article-layout container">
    <article class="content-card prose article-content-page">
      <Content />
    </article>
    <ArticleToc headings={headings} />
  </div>
  <div class="container"><PostExtras post={post} /><PostNav newer={newer} older={older} related={related} /></div>
  <script is:inline>
    document.querySelectorAll('pre').forEach((pre) => {
      if (pre.querySelector('.copy-code')) return;
      const code = pre.querySelector('code');
      const lang = Array.from(code?.classList || []).find((c) => c.startsWith('language-'))?.replace('language-', '') || 'code';
      pre.setAttribute('data-lang', lang);
      const btn = document.createElement('button');
      btn.className = 'copy-code';
      btn.type = 'button';
      btn.textContent = '复制';
      btn.addEventListener('click', async () => {
        const text = code?.innerText || pre.innerText.replace(/^复制\n?/, '');
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = '已复制';
          setTimeout(() => btn.textContent = '复制', 1200);
        } catch {
          btn.textContent = '失败';
        }
      });
      pre.appendChild(btn);

      if (lang === 'plantuml') {
        const tools = document.createElement('div');
        tools.className = 'diagram-tools';
        const online = document.createElement('a');
        online.href = 'https://www.plantuml.com/plantuml/uml/';
        online.target = '_blank';
        online.rel = 'noopener';
        online.textContent = 'PlantUML 在线渲染';
        const hint = document.createElement('span');
        hint.textContent = '复制源码后可粘贴渲染';
        tools.append(online, hint);
        pre.appendChild(tools);
      }
      if (lang === 'mermaid') {
        pre.classList.add('mermaid-source');
      }
    });
  </script>
</BaseLayout>
