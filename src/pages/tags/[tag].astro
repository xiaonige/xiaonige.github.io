---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPosts, uniqueSorted } from '@/lib/posts';
export async function getStaticPaths() {
  const posts = await getPosts();
  const tags = uniqueSorted(posts.flatMap((p) => p.data.tags || []));
  return tags.map((tag) => ({ params: { tag }, props: { tag, posts: posts.filter((p) => p.data.tags?.includes(tag)) } }));
}
const { tag, posts } = Astro.props;
---
<BaseLayout title={`标签：${tag}`}>
  <section class="content-card">
    <p class="eyebrow">TAG</p>
    <h1>#{tag}</h1>
    <div class="post-grid">{posts.map((post) => <PostCard post={post} />)}</div>
  </section>
</BaseLayout>
