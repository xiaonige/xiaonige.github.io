---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPosts, uniqueSorted } from '@/lib/posts';
const posts = await getPosts();
const tags = uniqueSorted(posts.flatMap((p) => p.data.tags || []));
---
<BaseLayout title="标签">
  <section class="page-hero small-hero tag-hero">
    <div class="cover-overlay"></div>
    <div class="page-hero-content">
      <h1>标签</h1>
      <p>用关键词给文章做一张地图。</p>
    </div>
  </section>
  <section class="content-card list-card">
    <p class="eyebrow"><i class="fas fa-tags"></i> TAGS</p>
    <div class="tag-cloud big-cloud">
      {tags.map((tag) => <a href={`/tags/${encodeURIComponent(tag)}/`}>#{tag}<small>{posts.filter((p) => p.data.tags?.includes(tag)).length}</small></a>)}
    </div>
  </section>
</BaseLayout>
