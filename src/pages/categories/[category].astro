---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPosts, uniqueSorted } from '@/lib/posts';
export async function getStaticPaths() {
  const posts = await getPosts();
  const categories = uniqueSorted(posts.flatMap((p) => p.data.categories || []));
  return categories.map((category) => ({ params: { category }, props: { category, posts: posts.filter((p) => p.data.categories?.includes(category)) } }));
}
const { category, posts } = Astro.props;
---
<BaseLayout title={`分类：${category}`}>
  <section class="page-hero small-hero category-hero">
    <div class="cover-overlay"></div>
    <div class="page-hero-content">
      <h1>{category}</h1>
      <p>共 {posts.length} 篇文章</p>
    </div>
  </section>
  <section class="container articles list-page-articles">
    <div class="row article-row">{posts.map((post) => <PostCard post={post} />)}</div>
  </section>
</BaseLayout>
