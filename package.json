{
  "name": "xiaonige-astro-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "npm run scan && npm run render:plantuml && astro build && npm run check:links",
    "preview": "astro preview --host 0.0.0.0",
    "migrate:hexo": "node scripts/migrate-hexo-posts.mjs",
    "scan": "node scripts/sensitive-scan.mjs",
    "render:plantuml": "node scripts/render-plantuml-drafts.mjs",
    "check:links": "node scripts/check-links.mjs",
    "promote:draft": "node scripts/promote-draft.mjs",
    "publish:preview": "node scripts/publish-preview.mjs"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.0",
    "astro": "5.10.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
